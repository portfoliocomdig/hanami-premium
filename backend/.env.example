# ── Servidor ─────────────────────────────────────────
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Banco de Dados (PostgreSQL) ────────────────────────
# Opção A: variáveis separadas (usado pelo docker-compose local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hanami_db
DB_USER=hanami_user
DB_PASSWORD=hanami_pass

# Opção B: connection string única (Neon, Supabase, Railway etc.)
# Se DATABASE_URL estiver preenchida, ela tem prioridade sobre as DB_* acima.
# DATABASE_URL=postgresql://usuario:senha@ep-xxx.neon.tech/hanami_db?sslmode=require

# ── Autenticação (JWT) ─────────────────────────────────
JWT_SECRET=troque_por_um_segredo_forte_em_producao
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=troque_por_outro_segredo_forte
JWT_REFRESH_EXPIRES_IN=7d

# ── PagBank (https://developer.pagbank.com.br) ─────────
# Ambiente sandbox: https://sandbox.api.pagseguro.com
# Ambiente produção: https://api.pagseguro.com
PAGBANK_API_URL=https://sandbox.api.pagseguro.com
PAGBANK_TOKEN=coloque_seu_token_de_autenticacao_pagbank
PAGBANK_PUBLIC_KEY=coloque_sua_chave_publica_pagbank
PAGBANK_WEBHOOK_SECRET=troque_por_um_segredo_de_validacao_de_webhook
